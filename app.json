{
  "expo": {
    "name": "BizKPI",
    "slug": "bizkpi",
    "scheme": "bizkpi",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06070B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bizkpi.app"
    },
    "android": {
      "package": "com.bizkpi.app",
      "adaptiveIcon": {
        "backgroundColor": "#06070B"
      },
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "updates": {
      "enabled": false
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9141ee69-1b40-4154-a527-041497b30ee7"
      }
    },
    "owner": "mtamrod"
  }
}
